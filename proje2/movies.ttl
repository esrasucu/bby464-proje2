@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://hacettepe.edu.tr/esra/ontology#> .

# --- CLASS DEFINITIONS ---
ex:Movie a rdfs:Class ;
         rdfs:label "Movie" ;
         rdfs:subClassOf schema:Movie .

ex:Director a rdfs:Class ;
            rdfs:label "Director" ;
            rdfs:subClassOf schema:Person .

# --- PROPERTY DEFINITIONS ---
ex:hasRating a rdf:Property ;
             rdfs:label "Rating" ;
             rdfs:domain ex:Movie ;
             rdfs:range xsd:decimal .

ex:releaseYear a rdf:Property ;
               rdfs:label "Release Year" ;
               rdfs:domain ex:Movie ;
               rdfs:range xsd:integer .

# --- INSTANCES & TRIPLES ---

# Directors
ex:D01 a ex:Director ; schema:name "Christopher Nolan" .
ex:D02 a ex:Director ; schema:name "Quentin Tarantino" .
ex:D03 a ex:Director ; schema:name "Bong Joon-ho" .
ex:D04 a ex:Director ; schema:name "Wes Anderson" .
ex:D05 a ex:Director ; schema:name "Stanley Kubrick" .
ex:D06 a ex:Director ; schema:name "Martin Scorsese" .
ex:D07 a ex:Director ; schema:name "Damien Chazelle" .
ex:D08 a ex:Director ; schema:name "Denis Villeneuve" .
ex:D09 a ex:Director ; schema:name "David Fincher" .

# Movies (21 Films)
ex:M01 a ex:Movie ; schema:name "Inception" ; ex:releaseYear "2010"^^xsd:integer ; ex:hasRating "8.8"^^xsd:decimal ; schema:director ex:D01 ; schema:genre "Sci-Fi" .
